# ─────────────────────────────────────────────────────
# Project Mind Vault — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────

# Option 1: Local SQLite (recommended for development)
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Option 2: Turso (recommended for production)
# DATABASE_URL=libsql://your-database-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# ── Obsidian Integration ──────────────────────────────

# Absolute path to your Obsidian vault folder
# Windows example: C:/Users/yourname/Documents/Obsidian/MyVault
# macOS example:   /Users/yourname/Documents/Obsidian/MyVault
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian-vault

# ── Application ───────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
